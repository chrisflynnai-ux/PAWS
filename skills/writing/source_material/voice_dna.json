{
  "meta": {
    "version": "1.0",
    "owner": "<your_name_or_brand>",
    "last_updated": "YYYY-MM-DD",
    "source_examples": [
      {
        "title": "Sample #1",
        "location": "knowledge/newsletters/sample_01.md",
        "notes": "Best representative of voice"
      }
    ]
  },

  "voice_summary": {
    "one_sentence_description": "<e.g., candid, sharp, optimistic realism with clear teaching>",
    "archetype": "<e.g., builder-teacher | contrarian-analyst | empathetic coach>",
    "primary_emotional_tone": ["<e.g., grounded>", "<e.g., urgent>", "<e.g., playful>"],
    "reader_feeling_goal": [
      "<what the reader should feel after reading>",
      "<e.g., 'seen and capable'>"
    ]
  },

  "priority_rules": [
    {
      "priority": 1,
      "rule": "<most important rule: clarity, brevity, directness, etc.>",
      "why_it_matters": "<1 line>",
      "do": ["<do example>", "<do example>"],
      "dont": ["<don't example>", "<don't example>"]
    }
  ],

  "tone_and_personality": {
    "traits_ranked": [
      { "trait": "<e.g., direct>", "weight": 10 },
      { "trait": "<e.g., warm>", "weight": 7 },
      { "trait": "<e.g., witty>", "weight": 5 }
    ],
    "what_to_avoid": [
      "<e.g., corporate jargon>",
      "<e.g., breathless hype>",
      "<e.g., vague inspiration>"
    ]
  },

  "style_mechanics": {
    "reading_level_target": "<e.g., grade 6-9>",
    "sentence_length_preferences": {
      "default": "<e.g., 10-18 words>",
      "allowed_variation": "<e.g., occasional 3-6 word punchline + occasional long explanatory sentence>"
    },
    "paragraphing": {
      "max_lines_per_paragraph": 3,
      "preferred_rhythm": "<e.g., 1/3/1 or short/short/medium>",
      "whitespace_bias": "high"
    },
    "formatting": {
      "bullets": "use for lists of 3+ items",
      "bolding": "bold key phrases sparingly (1-3 per section)",
      "headings": "use clear, specific subheads that promise value"
    }
  },

  "signature_moves": {
    "openers": [
      "<pattern: contrarian premise>",
      "<pattern: vivid scene>",
      "<pattern: short punch question>"
    ],
    "cadence_tools": [
      "triads (A, B, C)",
      "hard-cut verdict lines",
      "short punchline sentences after a long one"
    ],
    "analogy_style": {
      "frequency": "<e.g., 1 per piece>",
      "source_domains": ["<e.g., sports>", "<e.g., startups>", "<e.g., everyday life>"],
      "avoid_domains": ["<optional>"]
    },
    "humor_style": {
      "type": ["self-deprecating", "absurdity", "shared pain"],
      "limits": ["no punching down", "no sarcasm-only voice"]
    }
  },

  "lexicon": {
    "favorite_words_phrases": ["<phrase>", "<phrase>"],
    "banned_words_phrases": ["<phrase>", "<phrase>"],
    "replacement_map": {
      "<banned_word>": "<preferred_word>",
      "<banned_phrase>": "<preferred_phrase>"
    }
  },

  "argumentation_and_thinking": {
    "default_structure": "<e.g., claim → proof beats → implication → action>",
    "evidence_preferences": ["data", "examples", "contrasts", "first-principles reasoning"],
    "stance": "<e.g., calm certainty; no hedging unless necessary>"
  },

  "examples": {
    "do": [
      {
        "label": "DO — Strong voice match",
        "text": "<paste a short paragraph of your best writing>"
      }
    ],
    "dont": [
      {
        "label": "DON'T — Generic AI drift",
        "text": "<paste an example of what you do NOT want>"
      }
    ]
  },

  "qa_checks": [
    "Does it sound like a human with taste, not a template?",
    "Can a reader summarize the point in 10 seconds?",
    "Did we remove clichés and vague abstractions?",
    "Are there 1–2 quotable lines or crisp phrasings?",
    "Is formatting scannable (short paragraphs, clear subheads)?"
  ]
}
